{
	"name": "clean-nestjs-cli",
	"version": "2.2.3",
	"description": "A command-line interface tool designed to streamline the creation and management of Nest projects following Clean Architecture principles.",
	"bin": {
		"clean-nest": "./bin/index.js",
		"cnest": "./bin/index.js"
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"test:regression": "vitest run tests/regression",
		"test:e2e": "npm run build && vitest run tests/e2e",
		"test:coverage": "vitest run --coverage",
		"test:all": "npm run test:unit && npm run test:integration && npm run test:regression && npm run test:e2e",
		"validate": "npm run build && npm run test:all"
	},
	"keywords": [
		"nestjs",
		"cli",
		"clean",
		"architecture"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jheisonnovak/clean-nestjs-cli.git"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/jheisonnovak/clean-nestjs-cli/issues"
	},
	"homepage": "https://github.com/jheisonnovak/clean-nestjs-cli#readme",
	"dependencies": {
		"chalk": "^5.5.0",
		"commander": "^14.0.0",
		"inquirer": "^13.3.0",
		"ora": "^9.0.0",
		"pluralize": "^8.0.0",
		"ts-morph": "^27.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.0.0",
		"@types/pluralize": "^0.0.33",
		"@vitest/coverage-v8": "^2.1.9",
		"commander": "^14.0.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-prettier": "^5.2.2",
		"prettier": "^3.4.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.20.0",
		"vitest": "^2.1.9"
	}
}
